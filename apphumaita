<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Centro Comercial Ponta de Humaitá</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{
    background:#f4f6f9;
    font-family:'Segoe UI', sans-serif;
}

.topo{
    background:linear-gradient(135deg,#ff5722,#ff9800);
    color:white;
    padding:25px;
    text-align:center;
    position:relative;
}

.botoes-topo{
    position:absolute;
    top:15px;
    right:15px;
    display:flex;
    flex-direction:column;
    gap:10px;
}

.card-servico{
    border:none;
    border-radius:20px;
    transition:0.3s;
    cursor:pointer;
}

.card-servico:hover{
    transform:translateY(-5px);
}

.card-servico img{
    height:180px;
    object-fit:cover;
    border-top-left-radius:20px;
    border-top-right-radius:20px;
}

.btn-whatsapp{
    background:#25d366;
    color:white;
    border:none;
}

#painelAdmin{
    display:none;
    background:white;
    padding:20px;
    border-radius:20px;
    box-shadow:0 5px 20px rgba(0,0,0,0.1);
    margin-bottom:20px;
}

.carousel-item img{
    height:300px;
    object-fit:cover;
}
.preview-img{
    height:80px;
    border-radius:10px;
    margin:5px;
}
</style>
</head>
<body>

<div class="topo">
    <h2>CENTRO COMERCIAL PONTA DE HUMAITÁ</h2>
    <p>Os melhores profissionais da sua região</p>

    <div class="botoes-topo">
        <button class="btn btn-light shadow" onclick="inicio()">Início</button>
        <button class="btn btn-dark shadow" onclick="loginAdmin()">Admin</button>
    </div>
</div>

<div class="container mt-4">

<input type="text" id="buscar" class="form-control mb-4" placeholder="Buscar serviço..." onkeyup="renderizar()">

<div id="painelAdmin">
    <h5>Painel Administrativo</h5>
    <input type="hidden" id="editIndex">

    <input type="text" id="nome" class="form-control mb-2" placeholder="Nome">
    <input type="text" id="categoria" class="form-control mb-2" placeholder="Categoria">
    <textarea id="descricao" class="form-control mb-2" placeholder="Descrição"></textarea>
    <input type="text" id="telefone" class="form-control mb-2" placeholder="WhatsApp">

    <label><strong>Foto de Capa</strong></label>
    <input type="file" id="capa" class="form-control mb-2">

    <label><strong>Adicionar Fotos</strong></label>
    <input type="file" id="fotos" class="form-control mb-2" multiple>

    <div id="previewAdmin" class="mb-3"></div>

    <button class="btn btn-success w-100 mb-3" onclick="salvarServico()">Salvar Serviço</button>

    <div id="listaAdmin"></div>
</div>

<div class="row" id="lista"></div>

</div>

<!-- MODAL -->
<div class="modal fade" id="modalDetalhe">
<div class="modal-dialog modal-lg">
<div class="modal-content">
<div class="modal-body" id="conteudoModal"></div>
</div>
</div>
</div>

<script>

let servicos = JSON.parse(localStorage.getItem("servicos")) || [];

function salvarLocal(){
    localStorage.setItem("servicos",JSON.stringify(servicos));
}

function inicio(){
    document.getElementById("buscar").value="";
    document.getElementById("painelAdmin").style.display="none";
    renderizar();
}

function loginAdmin(){
    let senha = prompt("Digite a senha do admin:");
    if(senha==="1234"){
        document.getElementById("painelAdmin").style.display="block";
        renderizarAdmin();
    }else{
        alert("Senha incorreta");
    }
}

function salvarServico(){

let nome=document.getElementById("nome").value;
let categoria=document.getElementById("categoria").value;
let descricao=document.getElementById("descricao").value;
let telefone=document.getElementById("telefone").value;
let capaInput=document.getElementById("capa");
let fotosInput=document.getElementById("fotos");
let editIndex=document.getElementById("editIndex").value;

if(!nome || !categoria || !telefone){
    alert("Preencha os campos obrigatórios");
    return;
}

let antigo = editIndex!=="" ? servicos[editIndex] : null;
let novasFotos=[];
let arquivos=fotosInput.files;
let total=arquivos.length;
let lidos=0;

function finalizar(capaBase64){

    let fotosFinal = antigo && antigo.fotos ? [...antigo.fotos] : [];
    novasFotos.forEach(f=>fotosFinal.push(f));

    let novo={
        nome,
        categoria,
        descricao,
        telefone,
        capa: capaBase64 || (antigo ? antigo.capa : ""),
        fotos:fotosFinal
    };

    if(editIndex===""){
        servicos.push(novo);
    }else{
        servicos[editIndex]=novo;
        document.getElementById("editIndex").value="";
    }

    salvarLocal();
    renderizar();
    renderizarAdmin();
    limpar();
}

function processarCapa(){
    if(capaInput.files[0]){
        let reader=new FileReader();
        reader.onload=function(e){
            finalizar(e.target.result);
        }
        reader.readAsDataURL(capaInput.files[0]);
    }else{
        finalizar(null);
    }
}

if(total===0){
    processarCapa();
}else{
    for(let i=0;i<total;i++){
        let reader=new FileReader();
        reader.onload=function(e){
            novasFotos.push(e.target.result);
            lidos++;
            if(lidos===total){
                processarCapa();
            }
        }
        reader.readAsDataURL(arquivos[i]);
    }
}
}

function limpar(){
    document.getElementById("nome").value="";
    document.getElementById("categoria").value="";
    document.getElementById("descricao").value="";
    document.getElementById("telefone").value="";
    document.getElementById("capa").value="";
    document.getElementById("fotos").value="";
    document.getElementById("previewAdmin").innerHTML="";
}

function renderizar(){
    let busca=document.getElementById("buscar").value.toLowerCase();
    let lista=document.getElementById("lista");
    lista.innerHTML="";

    servicos.filter(s=>
        s.nome.toLowerCase().includes(busca) ||
        s.categoria.toLowerCase().includes(busca)
    ).forEach((s,index)=>{

        let fotoPrincipal = s.capa ? s.capa :
            (s.fotos && s.fotos.length>0 ? s.fotos[0] : 'https://via.placeholder.com/400x200');

        lista.innerHTML+=`
        <div class="col-lg-4 col-md-6 col-12 mb-4">
            <div class="card card-servico shadow" onclick="abrirDetalhe(${index})">
                <img src="${fotoPrincipal}">
                <div class="card-body">
                    <h5>${s.nome}</h5>
                    <strong>${s.categoria}</strong>
                </div>
            </div>
        </div>`;
    });
}

function abrirDetalhe(index){
    let s=servicos[index];
    let carouselId="carousel"+index;
    let fotosHTML="";

    let todasFotos=[];
    if(s.capa) todasFotos.push(s.capa);
    if(s.fotos) todasFotos=todasFotos.concat(s.fotos);

    todasFotos.forEach((f,i)=>{
        fotosHTML+=`
        <div class="carousel-item ${i===0?'active':''}">
            <img src="${f}" class="d-block w-100">
        </div>`;
    });

    document.getElementById("conteudoModal").innerHTML=`
        <div id="${carouselId}" class="carousel slide mb-3" data-bs-ride="carousel">
            <div class="carousel-inner">${fotosHTML}</div>
            <button class="carousel-control-prev" type="button" data-bs-target="#${carouselId}" data-bs-slide="prev">
                <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#${carouselId}" data-bs-slide="next">
                <span class="carousel-control-next-icon"></span>
            </button>
        </div>

        <h4>${s.nome}</h4>
        <strong>${s.categoria}</strong>
        <p class="mt-2">${s.descricao}</p>

        <a href="https://wa.me/55${s.telefone}" target="_blank" class="btn btn-whatsapp w-100">
            Falar no WhatsApp
        </a>
    `;

    new bootstrap.Modal(document.getElementById('modalDetalhe')).show();
}

function renderizarAdmin(){
    let listaAdmin=document.getElementById("listaAdmin");
    listaAdmin.innerHTML="<h6>Gerenciar Serviços</h6>";

    servicos.forEach((s,index)=>{
        listaAdmin.innerHTML+=`
        <div class="d-flex justify-content-between align-items-center border p-2 mb-2 rounded">
            <span>${s.nome} - ${s.categoria}</span>
            <div>
                <button class="btn btn-sm btn-primary" onclick="editar(${index})">Editar</button>
                <button class="btn btn-sm btn-danger" onclick="excluir(${index})">Excluir</button>
            </div>
        </div>`;
    });
}

function editar(index){
    let s=servicos[index];

    document.getElementById("nome").value=s.nome;
    document.getElementById("categoria").value=s.categoria;
    document.getElementById("descricao").value=s.descricao;
    document.getElementById("telefone").value=s.telefone;
    document.getElementById("editIndex").value=index;

    let preview=document.getElementById("previewAdmin");
    preview.innerHTML="";

    if(s.capa){
        preview.innerHTML+=`
        <div>
            <strong>Capa Atual:</strong><br>
            <img src="${s.capa}" class="preview-img">
            <button class="btn btn-sm btn-danger" onclick="removerCapa(${index})">Remover Capa</button>
        </div><hr>`;
    }

    if(s.fotos){
        s.fotos.forEach((f,i)=>{
            preview.innerHTML+=`
            <div class="d-inline-block position-relative">
                <img src="${f}" class="preview-img">
                <button class="btn btn-sm btn-danger position-absolute top-0 end-0"
                onclick="removerFoto(${index},${i})">X</button>
            </div>`;
        });
    }

    window.scrollTo(0,0);
}

function removerCapa(index){
    if(confirm("Remover capa?")){
        servicos[index].capa="";
        salvarLocal();
        editar(index);
        renderizar();
    }
}

function removerFoto(index,i){
    if(confirm("Remover foto?")){
        servicos[index].fotos.splice(i,1);
        salvarLocal();
        editar(index);
        renderizar();
    }
}

function excluir(index){
    if(confirm("Deseja excluir este serviço?")){
        servicos.splice(index,1);
        salvarLocal();
        renderizar();
        renderizarAdmin();
    }
}

renderizar();

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
